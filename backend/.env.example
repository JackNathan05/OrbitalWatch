# ---- Database ----
# Local: use the docker-compose TimescaleDB instance
# Railway: use the DATABASE_URL from your Railway PostgreSQL addon
DATABASE_URL=postgresql+asyncpg://orbital:orbital_dev@localhost:5432/orbitalwatch

# ---- Redis ----
# Local: use the docker-compose Redis instance
# Railway: use the REDIS_URL from your Railway Redis addon
REDIS_URL=redis://localhost:6379/0

# ---- Space-Track.org ----
# Register free at https://www.space-track.org/auth/createAccount
SPACETRACK_USERNAME=
SPACETRACK_PASSWORD=

# ---- CelesTrak ----
CELESTRAK_BASE_URL=https://celestrak.org

# ---- CORS ----
# Local: http://localhost:3000
# Production: your Vercel URL (e.g. https://orbitalwatch.vercel.app)
CORS_ORIGINS=http://localhost:3000

# ---- App ----
APP_ENV=development
