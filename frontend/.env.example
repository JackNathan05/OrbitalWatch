# ---- API ----
# Local: http://localhost:8000
# Production: your Railway backend URL (e.g. https://orbitalwatch-backend-production.up.railway.app)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Cesium ----
# Optional. Get a free token at https://ion.cesium.com/tokens
# Without it, the globe uses built-in Natural Earth imagery (works fine).
NEXT_PUBLIC_CESIUM_ION_TOKEN=
